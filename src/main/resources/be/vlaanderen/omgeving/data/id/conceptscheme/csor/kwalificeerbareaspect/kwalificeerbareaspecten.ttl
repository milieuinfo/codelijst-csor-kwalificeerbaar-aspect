<https://data.omgeving.vlaanderen.be/id/conceptscheme/csor/kwalificeerbaaraspect>
        rdf:type            skos:ConceptScheme;
        owl:deprecated      false;
        skos:definition     "Een kwalificeerbaar aspect drukt uit dat de waarde die aan een observatie kan worden toegekend, beperkt is tot classificaties opgenomen in een elders gepubliceerde lijst."@nl;
        skos:hasTopConcept  <https://data.omgeving.vlaanderen.be/id/concept/csor/kwalificeerbaaraspect/KWL_1>;
        skos:prefLabel      "Kwalificeerbaar aspect"@nl .
